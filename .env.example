# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Payment gateway (MoneyUnify)
MONEYUNIFY_AUTH_ID=your-auth-id

# CSRF — comma-separated list of allowed origins
ALLOWED_ORIGINS=rentatutor.co.zm,www.rentatutor.co.zm,admin.rentatutor.co.zm

# Email (contact form)
ALERT_EMAIL_FROM=noreply@rentatutor.co.zm
ALERT_EMAIL_TO=support@rentatutor.co.zm
